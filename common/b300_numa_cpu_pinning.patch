# Template for customizing optional Priority Core Turbo-related fixed-core CPU binding
# when your B300 system's PCT high-priority core IDs do not match the Megatron-Bridge
# reference binding. Edit the -C expression below before applying this patch.
# Validate the affected workload before using the patched configuration for benchmark
# submissions.
#
# Apply from the root of the Megatron-Bridge checkout:
#   git apply /path/to/b300_numa_cpu_pinning.patch
#
--- a/scripts/performance/utils/executors.py
+++ b/scripts/performance/utils/executors.py
@@ -139,5 +139,5 @@ def slurm_executor(
     numa_divisor = 2 if gpu.lower() in ["gb200", "gb300"] else 4
     numa_cmd = f"numactl --cpunodebind=$((SLURM_LOCALID/{numa_divisor})) --membind=$((SLURM_LOCALID/{numa_divisor}))"
     if gpu.lower() in ["b300"] and enable_pct_binding:
-        numa_cmd += " -C $((SLURM_LOCALID * 16)),$((SLURM_LOCALID * 16 + 1))"
+        numa_cmd += " -C $((SLURM_LOCALID * 16)),$((SLURM_LOCALID * 16 + 1))"  # Adjust exact binding to match your PCT cores
     custom_bash_cmds.append(numa_cmd)
